# ToonStream API Environment Variables
# Change this if ToonStream migrates to a new domain
TOONSTREAM_BASE_URL=https://toonstream.vip

# Default provider (toonstream | animesalt | hianime | animekai)
DEFAULT_PROVIDER=toonstream

# Request timeout in milliseconds
REQUEST_TIMEOUT=15000

# Cache TTL in seconds (default 5 minutes)
CACHE_TTL=300
